    },
    {
      "id": "a0M-4b0Vuw7Lge_ci1qNP",
      "type": "text",
      "x": 333.1901550292969,
      "y": 150,
      "width": 473.61968994140625,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
