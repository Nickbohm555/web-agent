      "isDeleted": false,
      "boundElements": null,
      "updated": 1774497365903,
      "link": null,
      "locked": false,
      "text": "1. ChatOpenAI + WebAgentClient\nInject the model and keep the runtime stateless",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "goal",
      "originalText": "1. ChatOpenAI + WebAgentClient\nInject the model and keep the runtime stateless",
      "autoResize": true,
      "lineHeight": 1.25,
      "syncedAt": "2026-03-26T03:56:11.215Z",
      "source": "frontend_sync",
      "syncTimestamp": "2026-03-26T03:56:11.211Z"
    },
    {
      "id": "fVX3XZG1dOSIsO0hP2Azu",
      "type": "text",
      "x": 335.8002014160156,
      "y": 305,
      "width": 468.39959716796875,
      "height": 100,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aF",
      "roundness": null,
      "seed": 848826060,
      "version": 1,
      "versionNonce": 2147244620,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774497365903,
      "link": null,
      "locked": false,
      "text": "2. web_search\nUse Serper to fetch ranked URLs, snippets, and\nresult metadata\nThis step only finds candidate pages",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "search",
      "originalText": "2. web_search\nUse Serper to fetch ranked URLs, snippets, and result metadata\nThis step only finds candidate pages",
      "autoResize": true,
      "lineHeight": 1.25,
      "syncedAt": "2026-03-26T03:56:11.215Z",
      "source": "frontend_sync",
      "syncTimestamp": "2026-03-26T03:56:11.211Z"
    },
    {
