      "text": "web-agent workflow: search is just two tools plus an LLM",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "title",
      "originalText": "web-agent workflow: search is just two tools plus an LLM",
