    {
      "id": "Aw4ny65HgtW5dlTrGruzb",
      "type": "text",
      "x": 333.1901550292969,
      "y": 150,
      "width": 473.61968994140625,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
