      "text": "web-agent workflow: search is just two tools plus an LLM",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "title",
      "originalText": "web-agent workflow: search is just two tools plus an LLM",
      "autoResize": true,
      "lineHeight": 1.25,
      "syncedAt": "2026-03-26T03:56:11.215Z",
      "source": "frontend_sync",
